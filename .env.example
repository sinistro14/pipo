# Application name
PIPO_APP=<app_name>

# Discord channel
PIPO_CHANNEL=<discord_channel>

# Discord default voice channel
PIPO_VOICE_CHANNEL=<discord_voice_channel>

# Discord API token
PIPO_TOKEN=<discord_token>

# AMQP broker address
PIPO_AMQP_BROKER_ADDRESS=<amqp_broker_address>

# AMQP virtual host
PIPO_AMQP_VIRTUAL_HOST=<amqp_virtual_host>

# AMQP user
PIPO_AMQP_USER=<amqp_user>

# AMQP password
PIPO_AMQP_PASSWORD=<amqp_password>
# Spotify API credentials
PIPO_SPOTIFY_CLIENT=<spotify_client_id>
PIPO_SPOTIFY_SECRET=<spotify_client_secret>
